{
  "author": "Tramaine L. Gillus",
  "dependencies": {
    "chevrotain": "12.0.0",
    "date-fns": "4.1.0",
    "effect": "3.21.0",
    "liqe": "3.8.5",
    "ohm-js": "17.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@ohm-js/cli": "2.0.1",
    "@release-it/conventional-changelog": "10.0.6",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "del-cli": "7.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "release-it": "19.2.4",
    "testdouble": "3.20.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "license": "MIT",
  "name": "dsl",
  "repository": {
    "type": "git",
    "url": "git@github.com:tgillus/dsl.git"
  },
  "scripts": {
    "build": "npm run clean && npm test && tsc",
    "clean": "del ./lib ./coverage",
    "format": "biome format --write --no-errors-on-unmatched .",
    "grammar:ohm": "ohm generateBundles --withTypes --esm 'src/filter/transpiler/parser/grammar/*.ohm'",
    "lint": "biome lint --no-errors-on-unmatched .",
    "lint:fix": "biome lint --fix --no-errors-on-unmatched .",
    "prepare": "husky",
    "release": "release-it --ci",
    "start:chevrotain": "tsx src/chevrotain/index.ts",
    "start:ohm": "tsx src/ohm/index.ts",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "tsc -c"
  },
  "type": "module",
  "version": "0.0.0"
}
