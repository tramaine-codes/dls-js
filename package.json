{
  "author": "Tramaine L. Gillus",
  "dependencies": {
    "chevrotain": "11.0.3",
    "date-fns": "4.1.0",
    "effect": "3.18.4",
    "liqe": "3.8.3",
    "ohm-js": "17.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@commitlint/cli": "20.1.0",
    "@commitlint/config-conventional": "20.0.0",
    "@ohm-js/cli": "2.0.1",
    "@release-it/conventional-changelog": "10.0.1",
    "@types/bun": "1.3.0",
    "@vitest/coverage-v8": "3.2.4",
    "del-cli": "7.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.4",
    "release-it": "19.0.5",
    "testdouble": "3.20.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "name": "dsl",
  "repository": {
    "type": "git",
    "url": "git@github.com:tgillus/dsl.git"
  },
  "scripts": {
    "build": "bun run clean && bun test && tsc",
    "clean": "del ./lib ./coverage",
    "format": "biome format --write --no-errors-on-unmatched .",
    "grammar:ohm": "ohm generateBundles --withTypes --esm 'src/filter/transpiler/parser/grammar/*.ohm'",
    "lint": "biome lint --no-errors-on-unmatched .",
    "lint:fix": "biome lint --apply --no-errors-on-unmatched .",
    "prepare": "husky",
    "release": "release-it --ci",
    "start:chevrotain": "bun src/chevrotain/index.ts",
    "start:ohm": "bun src/ohm/index.ts",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "tsc -c"
  },
  "type": "module",
  "version": "0.0.0"
}
